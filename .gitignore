# --------------------------------------------------------------------------
# GLOBAL FILES: Operating System and IDE
# --------------------------------------------------------------------------
# macOS system files
.DS_Store
# Windows system files
ehthumbs.db
Thumbs.db
# VS Code settings (use a .vscode/settings.json file for shared settings instead)
.vscode/
# JetBrains IDEs (IntelliJ, WebStorm, RustRover)
.idea/

# --------------------------------------------------------------------------
# RUST BACKEND (Simulation Server)
# Stack: Rust, Cargo, Bevy ECS, Axum, Tokio
# --------------------------------------------------------------------------
# Cargo build directory
/target/
apps/simulation/target/

# Cargo metadata and lock files
# Note: Cargo.lock should only be ignored for libraries, not applications
# For applications it should be tracked, but adding here as reference
Cargo.lock
.cargo/

# Local crates registry/cache
/crates/

# Local Rust-related files/folders
# Can be ignored if you don't want to enforce formatting rules
/rustfmt.toml
/clippy.toml

# --------------------------------------------------------------------------
# NODE.JS/TYPESCRIPT (Frontend Client & Economy Microservice)
# Stack: Node.js, npm/Yarn, TypeScript, Pixi.js, Vite
# --------------------------------------------------------------------------
# Dependency directory
/node_modules
apps/ledger/node_modules
apps/ui/node_modules

# Build output directories
/dist
/build
/out
apps/ledger/dist
apps/ui/dist
apps/ui/build

# State snapshot directories
/apps/portal/snapshots
/apps/simulation/snapshots

# Log files and npm debug
npm-debug.log*
.eslintcache

# Vite-specific cache/temp files
.vite/

# --------------------------------------------------------------------------
# DATABASE AND SECURITY
# Stack: PostgreSQL, SQLx, Local Dev Data
# --------------------------------------------------------------------------
# Local database file (if using a local non-Docker instance)
/game.db

# Environment and secrets files
# Sensitive environment variables for local secrets
.env
.env.*.local
# Sensitive Terraform variables (must be ignored)
.terraform.tfvars
# Terraform state and cache files (always ignore)
.terraform/

# --------------------------------------------------------------------------
# CLAUDE AGENT FILES
# --------------------------------------------------------------------------
# Files created by Claude Code for user-specific settings or memory
# Local overrides
.claude/settings.local.json
# Agent memory/cache
.claude/memory.json