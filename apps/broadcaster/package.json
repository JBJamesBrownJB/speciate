{
  "name": "@speciate/broadcaster",
  "version": "1.0.0",
  "description": "WebSocket broadcaster service that relays NATS simulation data to browser clients",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "websocket",
    "nats",
    "broadcaster",
    "real-time",
    "streaming"
  ],
  "author": "Speciate Team",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "nats": "^2.28.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
