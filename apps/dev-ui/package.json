{
  "name": "@speciate/dev-ui",
  "version": "0.1.0",
  "description": "Developer tools UI for Speciate simulation",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:trials": "node scripts/generate-trial-list.cjs",
    "dev": "npm run generate:trials && vite --port 5174",
    "build": "npm run generate:trials && tsc && vite build",
    "preview": "vite preview",
    "test:ipc": "node test-ipc.cjs",
    "test:trial": "node test-trial-loading.cjs",
    "test": "npm run test:ipc && npm run test:trial"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "msgpack-lite": "^0.1.26"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/msgpack-lite": "^0.1.11",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
