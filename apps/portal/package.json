{
  "name": "@simulation/portal",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "setup": "npm-run-all setup:*",
    "setup:install": "npm install",
    "setup:rust": "cd ../simulation && cargo build",
    "setup:frontend": "vite build",
    "dev": "npm-run-all --parallel dev:vite dev:electron",
    "dev:vite": "vite --host 0.0.0.0",
    "dev:electron": "cross-env NODE_ENV=development ELECTRON_DISABLE_SANDBOX=1 electron .",
    "dev:rust": "cd ../simulation && cargo build",
    "build": "npm-run-all build:*",
    "build:rust": "cd ../simulation && cargo build --release",
    "build:frontend": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "msgpack-lite": "^0.1.26",
    "pixi.js": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/ui": "^4.0.6",
    "cross-env": "^10.1.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.6"
  }
}
