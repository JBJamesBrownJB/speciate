+    #[test]
+    fn test_cached_cell_index_produces_exact_counting_sort_layout() {
+        // Guards the count-once/reuse-in-scatter optimization: the flat cell index
+        // cached in the count pass and read back in scatter must yield exactly the
+        // same bucket layout a textbook counting sort produces — every entity in the
+        // correct cell's [start, start+count) slice, contiguous non-overlapping
+        // slices, and every proxy carrying the right (x, y).
+        let mut grid = SpatialGrid::new(50.0);
+        grid.set_world_bounds(-10.0, 400.0, -10.0, 400.0);
+
+        // Fixed seed: three cells, one over-populated to exercise intra-cell packing.
+        // Cell A (0,0): three entities. Cell B (1,0): one. Cell C (0,1): two.
+        let a1 = Entity::from_raw(1);
+        let a2 = Entity::from_raw(2);
+        let a3 = Entity::from_raw(3);
+        let b1 = Entity::from_raw(4);
+        let c1 = Entity::from_raw(5);
+        let c2 = Entity::from_raw(6);
+        let entities = vec![
+            (a1, 10.0, 10.0, 0.0, 0.0, 1.0, 1.0),
+            (b1, 60.0, 10.0, 0.0, 0.0, 1.0, 1.0),
+            (a2, 20.0, 30.0, 0.0, 0.0, 1.0, 1.0),
+            (c1, 10.0, 60.0, 0.0, 0.0, 1.0, 1.0),
+            (a3, 40.0, 40.0, 0.0, 0.0, 1.0, 1.0),
+            (c2, 30.0, 70.0, 0.0, 0.0, 1.0, 1.0),
+        ];
+        grid.rebuild_parallel(entities.into_iter());
+
+        // Exact per-cell counts.
+        assert_eq!(grid.cell_slice_at(10.0, 10.0).1, 3, "cell A count");
+        assert_eq!(grid.cell_slice_at(60.0, 10.0).1, 1, "cell B count");
+        assert_eq!(grid.cell_slice_at(10.0, 60.0).1, 2, "cell C count");
+        assert_eq!(grid.entity_count(), 6);
+
+        // Slices are contiguous, non-overlapping, and cover [0, 6).
+        let mut slices = [
+            grid.cell_slice_at(10.0, 10.0),
+            grid.cell_slice_at(60.0, 10.0),
+            grid.cell_slice_at(10.0, 60.0),
+        ];
+        slices.sort_by_key(|(start, _)| *start);
+        let mut expected_start = 0u32;
+        for (start, count) in slices {
+            assert_eq!(start, expected_start, "slices must be contiguous with no gaps");
+            expected_start += count;
+        }
+        assert_eq!(expected_start, 6, "slices must exactly cover all proxies");
+
+        // Every entity landed in the correct cell (regardless of intra-cell order,
+        // which the parallel atomic scatter does not fix).
+        let cell_members = |x: f32, y: f32| -> std::collections::HashSet<Entity> {
+            grid.cell_proxies_at(x, y).iter().map(|p| p.entity).collect()
+        };
+        assert_eq!(
+            cell_members(10.0, 10.0),
+            [a1, a2, a3].into_iter().collect(),
+            "cell A membership"
+        );
+        assert_eq!(cell_members(60.0, 10.0), [b1].into_iter().collect(), "cell B membership");
+        assert_eq!(cell_members(10.0, 60.0), [c1, c2].into_iter().collect(), "cell C membership");
+
+        // Data integrity: each proxy carries the coordinates it was inserted with.
+        for p in &grid.proxies {
+            let expected = match p.entity {
+                e if e == a1 => (10.0, 10.0),
+                e if e == a2 => (20.0, 30.0),
+                e if e == a3 => (40.0, 40.0),
+                e if e == b1 => (60.0, 10.0),
+                e if e == c1 => (10.0, 60.0),
+                e if e == c2 => (30.0, 70.0),
+                _ => unreachable!(),
+            };
+            assert_eq!((p.x, p.y), expected, "proxy coords must survive scatter");
+        }
+    }
