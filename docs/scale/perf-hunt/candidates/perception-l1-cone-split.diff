+/// Test the CanStrategicVision marker drives the split strategic L1 pass.
+///
+/// The L1 cone scan was hoisted out of the main perception loop into a separate
+/// work-stealing pass keyed on the `CanStrategicVision` capability marker. This
+/// pins the invariant that the marker is assigned at spawn EXACTLY when
+/// `perception.range >= L1_CELL_SIZE`, and that L1Vision is populated for marked
+/// (strategic) creatures and stays empty for unmarked (myopic) ones - i.e. the
+/// split pass produces the same L1Vision membership as the old inline range gate.
+#[test]
+fn test_strategic_vision_marker_matches_range_gate_and_l1_population() {
+    use crate::simulation::core::SimulationBuilder;
+    use crate::simulation::creatures::builder::CritBuilder;
+    use crate::simulation::creatures::components::{CanStrategicVision, CritId};
+    use crate::simulation::spatial::constants::L1_CELL_SIZE;
+
+    let mut sim = SimulationBuilder::new().build();
+    sim.set_boundaries(300.0, 300.0);
+
+    // Strategic giant: range well above L1_CELL_SIZE (60m) -> should be marked.
+    let giant_id = sim.spawn_crit(
+        CritBuilder::new()
+            .at(150.0, 150.0)
+            .with_size(5.0)
+            .with_fov(180.0)
+            .facing(0.0)
+            .with_dormant_brain()
+            .with_all_capabilities(),
+    );
+
+    // Myopic creature: range well below L1_CELL_SIZE -> should NOT be marked.
+    let myopic_id = sim.spawn_crit(
+        CritBuilder::new()
+            .at(60.0, 150.0)
+            .with_size(1.5)
+            .with_fov(180.0)
+            .facing(0.0)
+            .with_dormant_brain()
+            .with_all_capabilities(),
+    );
+
+    // Surround the giant with sizeable neighbors so its FOV cone has non-empty cells.
+    for angle in (0..360).step_by(45) {
+        let rad = (angle as f32).to_radians();
+        sim.spawn_crit(
+            CritBuilder::new()
+                .at(150.0 + 80.0 * rad.cos(), 150.0 + 80.0 * rad.sin())
+                .with_size(2.0)
+                .with_dormant_brain()
+                .with_all_capabilities(),
+        );
+    }
+
+    for _ in 0..3 {
+        sim.update(0.016);
+    }
+
+    let world = sim.world_mut();
+    let mut giant = None;
+    let mut myopic = None;
+    for (e, id) in world.query::<(Entity, &CritId)>().iter(world) {
+        if id.0 == giant_id {
+            giant = Some(e);
+        } else if id.0 == myopic_id {
+            myopic = Some(e);
+        }
+    }
+    let giant = giant.expect("giant should exist");
+    let myopic = myopic.expect("myopic should exist");
+
+    // Marker membership must match the range gate exactly.
+    let giant_range = world.get::<Perception>(giant).unwrap().range;
+    let myopic_range = world.get::<Perception>(myopic).unwrap().range;
+    assert!(giant_range >= L1_CELL_SIZE);
+    assert!(myopic_range < L1_CELL_SIZE);
+
+    assert!(
+        world.get::<CanStrategicVision>(giant).is_some(),
+        "long-range giant (range {giant_range:.1}m) must carry CanStrategicVision"
+    );
+    assert!(
+        world.get::<CanStrategicVision>(myopic).is_none(),
+        "myopic creature (range {myopic_range:.1}m) must NOT carry CanStrategicVision"
+    );
+
+    // L1Vision population must follow the marker: populated for the giant, empty
+    // for the myopic creature (the strategic pass only ever touches marked entities).
+    assert!(
+        world.get::<L1Vision>(giant).unwrap().count() > 0,
+        "strategic pass should populate the giant's L1Vision"
+    );
+    assert_eq!(
+        world.get::<L1Vision>(myopic).unwrap().count(),
+        0,
+        "unmarked myopic creature's L1Vision must stay empty"
+    );
+}
